# Server
PORT=3000
BASE_URL=http://localhost:3000

# Storage
UPLOAD_DIR=/data/uploads
DB_PATH=/data/db/lobdrop.db
MAX_FILE_SIZE_MB=100

# Files
FILE_EXPIRY_DAYS=7

# SMTP (optional — leave blank to disable email invites)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_SECURE=false

# Authentication
ADMIN_USER=admin
ADMIN_PASS=change-me-to-a-secure-password

# Security
SECRET_KEY=change-me-to-a-random-string
CORS_ORIGIN=*

# Docker user mapping
PUID=1000
PGID=1000
